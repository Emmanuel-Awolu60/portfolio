{
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ],
  "compilerOptions": {
    "jsx": "react-jsx", // or "react" for older versions
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "skipLibCheck": true,
    "target": "es5", // Ensures compatibility with older environments
    "module": "esnext", // Use modern modules
    "lib": [
      "dom",
      "esnext"
    ],
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "typeRoots": [
      "node_modules/@types"
    ]
  }
}